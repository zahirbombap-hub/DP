/static/*
  Cache-Control: public, max-age=31536000, immutable

/multimedia/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/robots.txt
  Cache-Control: public, max-age=86400

/
  Cache-Control: no-cache, max-age=0, must-revalidate

/index.html
  Cache-Control: no-cache, max-age=0, must-revalidate
